{
  "uid": "dfkv-connector",
  "title": "Connector",
  "tags": [
    "dfkv",
    "telemetry"
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "connector_type",
        "label": "Connector type",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(dfkv_connector_info, dfkv_connector_type)",
          "refId": "A"
        },
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1
      },
      {
        "type": "query",
        "name": "connector_id",
        "label": "Connector id",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(dfkv_connector_info{dfkv_connector_type=~\"$connector_type\"}, dfkv_connector_id)",
          "refId": "A"
        },
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Connectors",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count(dfkv_connector_info{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"})",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total requests/s",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "fixed"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(dfkv_connector_ops_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval]))"
        }
      ]
    },
