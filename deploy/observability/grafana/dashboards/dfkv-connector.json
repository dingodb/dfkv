{
  "title": "Connector",
  "uid": "dfkv-connector",
  "tags": [
    "dfkv",
    "telemetry"
  ],
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "connector_type",
        "label": "Connector type",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(dfkv_connector_info, dfkv_connector_type)",
          "refId": "A"
        },
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1
      },
      {
        "type": "query",
        "name": "connector_id",
        "label": "Connector id",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(dfkv_connector_info{dfkv_connector_type=~\"$connector_type\"}, dfkv_connector_id)",
          "refId": "A"
        },
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Connectors",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": ""
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count(group by (dfkv_connector_id) (dfkv_connector_info{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}))"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total requests/s",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(sum(rate(dfkv_connector_op_requests_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval]))) or (sum(rate(dfkv_connector_ops_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])))"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total keys/s",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "/ s"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(sum(rate(dfkv_connector_op_keys_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval]))) or (sum(rate(dfkv_connector_keys_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])))"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total bandwidth",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(sum(rate(dfkv_connector_op_bytes_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval]))) or (sum(rate(dfkv_connector_bytes_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])))"
        }
      ]
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "By type",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "legend": {
          "displayMode": "list",
          "placement": "right"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count by (dfkv_connector_type) (dfkv_connector_info{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"})",
          "legendFormat": "{{dfkv_connector_type}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "piechart",
      "title": "By native version",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "legend": {
          "displayMode": "list",
          "placement": "right"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count by (dfkv_native_version) (dfkv_connector_info{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"})",
          "legendFormat": "{{dfkv_native_version}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "row",
      "title": "By operation (put / get / exist \u2014 C++ chokepoint; old put/get shown until the connector rollout)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "panels": []
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Requests/s by op",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(sum by (op) (rate(dfkv_connector_op_requests_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval]))) or (sum by (op) (rate(dfkv_connector_ops_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])))",
          "legendFormat": "{{op}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Keys/s by op",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "/ s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(sum by (op) (rate(dfkv_connector_op_keys_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval]))) or (sum by (op) (rate(dfkv_connector_keys_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])))",
          "legendFormat": "{{op}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Bandwidth by op",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(sum by (op) (rate(dfkv_connector_op_bytes_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval]))) or (sum by (op) (rate(dfkv_connector_bytes_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])))",
          "legendFormat": "{{op}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Success ratio by op (put=write-ok, get=hit, exist=present) \u2014 needs rollout",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (op)(rate(dfkv_connector_op_hits_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])) / clamp_min(sum by (op)(rate(dfkv_connector_op_keys_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])),1)",
          "legendFormat": "{{op}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Failed / missed keys/s by op (put = 'Write page' failures) \u2014 needs rollout",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "unit": "/ s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (op)(rate(dfkv_connector_op_keys_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval]) - rate(dfkv_connector_op_hits_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval]))",
          "legendFormat": "{{op}}"
        }
      ],
      "description": "put: pages that failed to write (SGLang 'Write page to storage: N pages failed'); get/exist: misses. Populates after the new connector rollout."
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Latency avg by op",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(sum by (op)(rate(dfkv_connector_op_latency_seconds_sum{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])) / clamp_min(sum by (op)(rate(dfkv_connector_op_latency_seconds_count{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])),1)) or (sum by (op)(rate(dfkv_connector_op_seconds_sum{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])) / clamp_min(sum by (op)(rate(dfkv_connector_op_seconds_count{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])),1))",
          "legendFormat": "{{op}}"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Latency p99 by op",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 26
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(histogram_quantile(0.99, sum by (op,le)(rate(dfkv_connector_op_latency_seconds_bucket{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])))) or (histogram_quantile(0.99, sum by (op,le)(rate(dfkv_connector_op_seconds_bucket{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval]))))",
          "legendFormat": "{{op}}"
        }
      ],
      "description": "Buckets saturate at 100ms; for the multi-second tail see the max panel."
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Latency MAX by op (the batch_exist tail)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 26
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (op)(dfkv_connector_op_max_seconds{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"})",
          "legendFormat": "{{op}}"
        }
      ],
      "description": "Lifetime peak per op. A spike on op=exist is the scheduler-freezing stall."
    },
    {
      "id": 16,
      "type": "row",
      "title": "Per-cache-node latency (active prober)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 33
      },
      "panels": []
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Probe cache latency by peer",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "avg by (peer)(dfkv_client_peer_latency_avg_seconds{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"})",
          "legendFormat": "avg {{peer}}"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (peer)(dfkv_client_peer_latency_max_seconds{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"})",
          "legendFormat": "max {{peer}}"
        }
      ]
    }
  ]
}